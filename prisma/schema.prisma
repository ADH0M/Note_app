generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
}

model User {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  username String
  email    String   @unique
  password String
  isActive Boolean  @default(false)
  type     UserType @default(customer)
  phone    String?  @unique
  photo    String?

  projects  Project[]
  notes     Note[]
  tasks     Task[]
  adminLogs AdminAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ai relations
  aiTaskSuggestions AITaskSuggestion[]
  aiSummaries       AISummary[]
  aiDailyPlans      AIDailyPlan[]
  aiConversations   AIConversation[]
  aiAnalytics       AIAnalytics[]
}

model Project {
  id    String      @id @default(auto()) @map("_id") @db.ObjectId
  title String
  type  ProjectType @default(todo)
  order Float       @default(0)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  columns Column[]
  tasks   Task[]
  notes   Note[]

  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Column {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  title String
  order Float  @default(0)

  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Task {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  content    String?
  favorite   Boolean   @default(false)
  state      Boolean   @default(false)
  order      Float     @default(0)
  priority   Priority  @default(medium)
  dueDate    DateTime?
  startDate  DateTime?
  timeSpent  Int       @default(0)
  hourlyRate Float?

  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  columnId String? @db.ObjectId
  column   Column? @relation(fields: [columnId], references: [id], onDelete: Cascade)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  aitaskSuggestions AITaskSuggestion[]

  @@index([projectId])
  @@index([columnId])
  @@index([userId])
}

enum Priority {
  low
  medium
  high
  urgent
}

model Note {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meetingDate DateTime?
  attendees   String[]
  tags        String[]
  actionItems Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model AdminAction {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  adminId String @db.ObjectId
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  action String
  data   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
}

enum ProjectType {
  todo
  project_tracker
  meeting_notes
  task_tracker
}

enum UserType {
  customer
  admin
}

model PasswordReset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------//
// Ai schema
model AITaskSuggestion {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  taskTitle       String
  taskDescription String?
  suggestedTime   String
  tips            String
  userId          String   @db.ObjectId
  taskId          String?  @db.ObjectId
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([taskId])
}

model AISummary {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  originalText String
  summary      String
  insights     String[] // Array of insights
  userId       String   @db.ObjectId
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIDailyPlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  plan        String
  userMessage String?
  tasks       Json // Store tasks as JSON
  userId      String   @db.ObjectId
  date        DateTime @default(now())
  executed    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model AIConversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  messages  Json // Store conversation history
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIAnalytics {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  feature      AiFeature @default(suggestion)
  tokensUsed   Int       @default(0)
  responseTime Int // in milliseconds
  success      Boolean   @default(true)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
}

enum AiFeature {
  suggestion
  summary
  plan
  coach
}
